# ── Desarrollo local ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/pronostats_ufc
SECRET_KEY=cambia-esta-clave
JWT_SECRET=cambia-este-jwt-secret
JWT_EXPIRE_MINUTES=60
API_SPORTS_KEY=
MMA_API_URL=https://v1.mma.api-sports.io
MMA_FIGHTS_ENDPOINT=/fights
MMA_EVENTS_ENDPOINT=/events
MMA_FIGHTERS_ENDPOINT=/fighters
MMA_FIGHTER_CATEGORIES="Flyweight,Bantamweight,Featherweight,Lightweight,Welterweight,Middleweight,Light Heavyweight,Heavyweight,Women's Strawweight,Women's Flyweight,Women's Bantamweight,Women's Featherweight"
MMA_FIGHTER_CATEGORY_LIMIT=2
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLIC_KEY=
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
APP_ENV=desarrollo
APP_DEBUG=true
SQLITE_FALLBACK_HABILITADO=true
SQLITE_FALLBACK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
CORREO_REMITENTE=no-reply@pronostats.local
RESEND_API_KEY=
GUARDAR_CODIGOS_DESARROLLO=true
ADMIN_USUARIO=Dana White
ADMIN_CORREO=admin@example.com
ADMIN_PASSWORD=cambia-esta-clave-admin
CLERK_ISSUER_URL=https://precious-alien-55.clerk.accounts.dev
CLERK_WEBHOOK_SECRET=
CLERK_SECRET_KEY=

